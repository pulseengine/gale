/// Reentrant mutex interface for Gale kernel.
///
/// Provides a formally verified reentrant mutex with ownership tracking,
/// matching Zephyr's k_mutex API.  Thread identity and blocking are
/// managed internally by the Kiln runtime -- the WASM component sees
/// lock/try-lock/unlock operations.
///
/// Verified properties (ASIL-D):
///   M1: lock_count > 0 iff owner exists (always)
///   M3: try-lock on unlocked mutex acquires it
///   M4: try-lock by owner increments lock count (reentrant)
///   M5: try-lock by non-owner returns would-block
///   M6: unlock by non-owner returns error
///   M7: unlock when lock_count > 1 decrements count
///   M8: unlock when lock_count == 1 transfers or releases
///   M10: no arithmetic overflow in lock count
///
/// Requirement: SWREQ-KILN-001

interface kernel-mutex {
    use kernel-error.{kernel-error};

    /// Result of a lock attempt.
    enum lock-result {
        /// Lock acquired (first time or reentrant).
        acquired,
        /// Mutex locked by another thread, caller chose not to wait.
        would-block,
    }

    /// Result of an unlock operation.
    enum unlock-result {
        /// Lock count decremented, mutex still held by current owner.
        released,
        /// Fully unlocked, no waiters were present.
        unlocked,
        /// Ownership transferred to highest-priority waiter.
        transferred,
    }

    /// A reentrant mutex with ownership tracking.
    ///
    /// Opaque handle to a kernel mutex object managed by the Kiln
    /// runtime.  Thread identity for ownership checks is provided
    /// by the runtime, not by the WASM component.
    resource mutex {
        /// Create a new mutex (starts unlocked).
        constructor();

        /// Try to lock the mutex without blocking.
        ///
        /// If unlocked, acquires the mutex (lock_count = 1).
        /// If locked by the calling thread, increments lock_count (reentrant).
        /// If locked by another thread, returns `would-block`.
        try-lock: func() -> result<lock-result, kernel-error>;

        /// Unlock the mutex.
        ///
        /// Returns `not-permitted` if the caller is not the owner.
        /// Returns `released` if lock_count was decremented but mutex still held.
        /// Returns `unlocked` if fully unlocked with no waiters.
        /// Returns `transferred` if ownership was passed to a waiter.
        unlock: func() -> result<unlock-result, kernel-error>;

        /// Check if the mutex is currently locked.
        is-locked: func() -> bool;

        /// Get the current lock count (nesting depth).
        lock-count-get: func() -> u32;
    }
}
