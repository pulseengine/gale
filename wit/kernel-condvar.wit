/// Condition variable interface for Gale kernel.
///
/// Provides a formally verified condition variable matching Zephyr's
/// k_condvar API.  A condvar is a pure wait queue -- threads wait on
/// it (releasing a held mutex atomically) and are woken by signal
/// (one) or broadcast (all).
///
/// Thread blocking and mutex integration are managed internally by
/// the Kiln runtime.  The WASM component sees signal/broadcast/wait
/// operations.  The wait operation accepts a mutex handle as an
/// opaque u32 token -- the Kiln runtime resolves this to the actual
/// mutex and performs the atomic unlock-wait-relock protocol.
///
/// Verified properties (ASIL-D):
///   C1: after init, wait queue is empty
///   C2: signal wakes at most one waiter (highest priority)
///   C3: signal on empty condvar is a no-op
///   C4: broadcast wakes all waiters, returns woken count
///   C5: broadcast on empty condvar returns 0
///   C7: signal/broadcast preserve wait queue ordering
///   C8: no arithmetic overflow in broadcast woken count
///
/// Requirement: SWREQ-KILN-001

interface kernel-condvar {
    use kernel-error.{kernel-error};

    /// Result of a signal operation.
    enum signal-result {
        /// No thread was waiting -- signal was a no-op.
        empty,
        /// The highest-priority waiting thread was woken.
        woke-thread,
    }

    /// A condition variable.
    ///
    /// Opaque handle to a kernel condvar object managed by the Kiln
    /// runtime.  The condvar must be used together with a mutex; the
    /// runtime handles the atomic unlock-and-wait / wake-and-relock
    /// protocol.
    resource condvar {
        /// Create a new condition variable.
        constructor();

        /// Signal the condvar -- wake one waiter.
        ///
        /// If threads are waiting, the highest-priority waiter is
        /// woken.  If no threads are waiting, this is a no-op.
        signal: func() -> result<signal-result, kernel-error>;

        /// Broadcast the condvar -- wake all waiters.
        ///
        /// Wakes all waiting threads and returns the count of threads
        /// that were woken.  Returns 0 if no threads were waiting.
        broadcast: func() -> result<u32, kernel-error>;

        /// Wait on the condvar, releasing the associated mutex.
        ///
        /// The calling thread atomically releases the mutex identified
        /// by `mutex-handle` and blocks on the condvar's wait queue.
        /// When woken (by signal or broadcast), the thread re-acquires
        /// the mutex before this call returns.
        ///
        /// The `mutex-handle` is a runtime-opaque token (resource rep)
        /// that identifies which mutex to release.  The Kiln runtime
        /// validates that the caller owns the referenced mutex.
        ///
        /// Returns `not-permitted` if the caller does not hold the mutex.
        /// Returns `invalid-argument` if the mutex handle is invalid.
        wait: func(mutex-handle: u32) -> result<_, kernel-error>;

        /// Get the number of threads waiting on this condvar.
        num-waiters: func() -> u32;
    }
}
