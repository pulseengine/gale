config GALE_KERNEL_TIMEOUT
	bool "Use Gale formally verified timeout"
	help
	  Use Gale formally verified tick arithmetic for kernel/timeout.c.
	  Deadline computation, overflow checks, and expiry detection are
	  handled by verified Rust code. Linked-list management, spinlock,
	  callbacks, and hardware timer remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_POLL
