config GALE_KERNEL_SEM
	bool "Use Gale formally verified semaphore"
	depends on MULTITHREADING
	help
	  Replace kernel/sem.c with the Gale formally verified Rust
	  implementation. Requires a Rust toolchain for the target
	  architecture.

if GALE_KERNEL_SEM

config GALE_MAX_SEMS
	int "Maximum number of Gale semaphores"
	default 32
	help
	  Maximum number of concurrently active semaphores. Each
	  semaphore is pre-allocated from a static pool at build time.

config GALE_MAX_WAITERS
	int "Maximum waiters per semaphore"
	default 16
	help
	  Maximum number of threads that can block on a single
	  semaphore. Bounded by the heapless::Vec in gale::WaitQueue.

endif # GALE_KERNEL_SEM

config GALE_KERNEL_MUTEX
	bool "Use Gale formally verified mutex"
	depends on MULTITHREADING
	help
	  Replace kernel/mutex.c with the Gale formally verified Rust
	  implementation. The ownership validation and lock_count
	  arithmetic are handled by verified Rust code. Wait queue,
	  scheduling, and priority inheritance remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_CONDVAR
	bool "Use Gale formally verified condvar"
	depends on MULTITHREADING
	help
	  Mark kernel/condvar.c wait queue operations as verified by
	  Gale. Condvar is a pure wait queue wrapper with no FFI —
	  the upstream condvar.c is still compiled, but its wait queue
	  operations are covered by Gale's Verus proofs.

config GALE_KERNEL_MSGQ
	bool "Use Gale formally verified message queue"
	help
	  Replace kernel/msg_q.c with the Gale formally verified Rust
	  implementation. The ring buffer index arithmetic is handled
	  by verified Rust code. Wait queue, scheduling, memcpy,
	  polling, and tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_STACK
	bool "Use Gale formally verified stack"
	depends on MULTITHREADING
	help
	  Replace kernel/stack.c with the Gale formally verified Rust
	  implementation. The LIFO capacity check and count tracking
	  are handled by verified Rust code. Wait queue, scheduling,
	  data storage, and tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_PIPE
	bool "Use Gale formally verified pipe"
	depends on MULTITHREADING
	help
	  Replace kernel/pipe.c with the Gale formally verified Rust
	  implementation. The state machine validation and byte count
	  computation are handled by verified Rust code. Ring buffer
	  data transfer, wait queues, scheduling, direct-copy, and
	  tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_EVENT
	bool "Use Gale formally verified event"
	depends on MULTITHREADING
	depends on EVENTS
	help
	  Replace kernel/events.c with the Gale formally verified Rust
	  implementation. The bitmask operations (post, set, clear,
	  set_masked, wait condition checks) are handled by verified
	  Rust code. Wait queues, scheduling, tracing, and userspace
	  remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_MEM_SLAB
	bool "Use Gale formally verified memory slab"
	help
	  Replace kernel/mem_slab.c with the Gale formally verified Rust
	  implementation. The block count tracking (num_used increment
	  and decrement) is handled by verified Rust code. Free-list
	  management, wait queues, scheduling, pointer validation,
	  statistics, and tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_TIMER
	bool "Use Gale formally verified timer"
	depends on MULTITHREADING
	help
	  Use Gale formally verified status counter arithmetic for
	  kernel/timer.c. The status increment (checked for overflow)
	  and status read-reset operations are handled by verified
	  Rust code. Timeout scheduling, callbacks, work queues, and
	  tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_FIFO
	bool "Use Gale formally verified fifo"
	depends on MULTITHREADING
	help
	  Replace the k_fifo count tracking in kernel/queue.c with the
	  Gale formally verified Rust implementation. The unbounded
	  queue counter increment/decrement is handled by verified
	  Rust code. Linked list management, wait queues, scheduling,
	  alloc nodes, polling, and tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_LIFO
	bool "Use Gale formally verified lifo"
	depends on MULTITHREADING
	help
	  Replace the k_lifo count tracking in kernel/queue.c with the
	  Gale formally verified Rust implementation. The unbounded
	  queue counter increment/decrement is handled by verified
	  Rust code. Linked list management, wait queues, scheduling,
	  alloc nodes, polling, and tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_QUEUE
	bool "Use Gale formally verified queue"
	depends on MULTITHREADING
	help
	  Replace kernel/queue.c with the Gale formally verified Rust
	  implementation. The unbounded queue counter for append,
	  prepend, and get operations is handled by verified Rust code.
	  Linked list management, wait queues, scheduling, alloc nodes,
	  polling, and tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.

config GALE_KERNEL_MBOX
	bool "Use Gale formally verified mailbox"
	depends on MULTITHREADING
	help
	  Replace kernel/mailbox.c with the Gale formally verified Rust
	  implementation. The send validation, message ID matching, and
	  data exchange size computation are handled by verified Rust
	  code. Wait queues, scheduling, async message descriptors,
	  data copy, and tracing remain native Zephyr C.
	  Requires a Rust toolchain for the target architecture.
