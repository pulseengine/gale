            <ATTRIBUTE-VALUE-STRING THE-VALUE="Expose kernel to hardware interrupts">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_30bfa47992cc41e69a9ed94226501b7b_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="The Zephyr RTOS shall provide an interface for managing a defined set of hardware exceptions (including interrupts) across all systems.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_30bfa47992cc41e69a9ed94226501b7b_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="As a Zephyr RTOS user I want hardware exceptions (hardware failures, programming mistakes) to be handled gracefully (no program crashes as far as possible).">
