            <ATTRIBUTE-VALUE-STRING THE-VALUE="Mutex">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_bf71fa4285f44d9697db5f69f30c3354_COMPONENT</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Mutex Kernel Object">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_bf71fa4285f44d9697db5f69f30c3354_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="The Zephyr RTOS shall support resource synchronization. (Note synchronization can be for memory access, and mutex may be one implementation, but not the only one).">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_bf71fa4285f44d9697db5f69f30c3354_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="As a Zephyr RTOS user I want to be able to sychonize threads when accessing common resources, where the thread shall have the option to:\n- wait eternally until the resources becomes available.\n- immediately return with a negative message if the resource is not available and allow the thread to continue.\n- wait for a given time for the resource to become available or return with a negative message.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_bf71fa4285f44d9697db5f69f30c3354_USER_STORY</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_bf71fa4285f44d9697db5f69f30c3354</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
