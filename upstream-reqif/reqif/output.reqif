            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Assigning memory pools to act as a thread resource pool">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_e812cc4184fa4bddbee97de608ba1960_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="The Zephyr RTOS shall support assigning a memory pool to act as that thread&#x27;s resource pool.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_e812cc4184fa4bddbee97de608ba1960_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="As a Zephyr RTOS user I want to be able, during runtime from the kernel, to request a memory area/pool which is exclusively available to the requesting thread protected against access from other threads.">
