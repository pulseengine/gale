# rules_renode (pinned commit 5fc76ad) predates Bazel 8's removal of the
# autoloaded Python globals: its renode/defs.bzl references PyInfo / py_* as
# builtins, which Bazel 9.1 no longer provides, so the module fails to LOAD
# ("name 'PyInfo' is not defined"). Re-inject the legacy globals from rules_python
# via the migration flag so the pinned rule loads unmodified. Upstream fix
# (load PyInfo from @rules_python//python:defs.bzl) reported to renode-bazel-rules.
common --incompatible_autoload_externally=PyInfo,PyRuntimeInfo,py_binary,py_test,py_library,py_runtime

# rules_renode transitively pulls rules_python 1.7.0; the module declares 0.36.0
# as a direct dep. The resolved 1.7.0 is fine for the autoload shim — silence the
# direct-dependency version-skew error rather than pin a stale rules_python.
common --check_direct_dependencies=off
