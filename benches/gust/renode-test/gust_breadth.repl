// Cortex-M3 + 64 KB SRAM / 512 KB flash + RAM-mapped register windows for the
// 4-driver BREADTH node content-gate (REQ-DRV-BREADTH-001). GPIO/timer/SPI windows
// are plain memory (the gate asserts the exact register values the DISSOLVED
// drivers write — deterministic, no Renode peripheral-model dependence); USART1 is
// the real STM32_UART model, which the dissolved uart driver TXes the proof line on.
cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic
nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    -> cpu@0
flash: Memory.MappedMemory @ sysbus 0x0
    size: 0x80000
sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x10000
tim2: Memory.MappedMemory @ sysbus 0x40000000
    size: 0x400
gpioc: Memory.MappedMemory @ sysbus 0x40011000
    size: 0x400
spi1: Memory.MappedMemory @ sysbus 0x40013000
    size: 0x400
usart1: UART.STM32_UART @ sysbus <0x40013800, +0x100>
    -> nvic@37
