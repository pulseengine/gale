// Cortex-M3 + 8 KB SRAM — the gust 8 KB device class (STM32F100RB-equivalent
// RAM). Flash at 0x0 (the dissolved gust ELF's layout). The SemihostingUart
// captures the kernel's hprintln heartbeat.
cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic
nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    -> cpu@0
flash: Memory.MappedMemory @ sysbus 0x0
    size: 0x40000
sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x2000
uartSemihosting: UART.SemihostingUart @ cpu
