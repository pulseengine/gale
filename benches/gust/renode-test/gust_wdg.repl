// Cortex-M3 + 64 KB SRAM / 512 KB flash, plus a RAM-mapped IWDG register window for
// the thin-seam IWDG driver content-gate. The gate asserts the exact KR key-sequence
// writes (0x5555 unlock / 0xCCCC start / 0xAAAA refresh) + PR/RLR config the DRIVER
// writes, and the Kani-proven cannot-un-start property — on a plain memory region,
// deterministic, no dependence on Renode's IWDG peripheral model.
cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic
nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    -> cpu@0
flash: Memory.MappedMemory @ sysbus 0x0
    size: 0x80000
sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x10000
// IWDG register window (real STM32F1 address, 0x40003000, +0x400) as plain memory —
// driver KR/PR/RLR writes read back. Ends at 0x40003400, below USART1 at 0x40013800
// (no overlap).
iwdg: Memory.MappedMemory @ sysbus 0x40003000
    size: 0x400
usart1: UART.STM32_UART @ sysbus <0x40013800, +0x100>
    -> nvic@37
